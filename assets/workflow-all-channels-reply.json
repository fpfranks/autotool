    {
      "parameters": {
        "jsCode": "// Normalise Gmail input into standard enquiry format\nconst data = $json;\nconst from = data.From || data.from || '';\nconst nameMatch = from.match(/^([^<]+)/);\nconst senderName = nameMatch ? nameMatch[1].trim() : from;\nconst emailMatch = from.match(/<([^>]+)>/);\nconst senderContact = emailMatch ? emailMatch[1] : from;\n\nreturn [{\n  json: {\n    channel_source: 'email',\n    sender_name: senderName,\n    sender_contact: senderContact,\n    message_content: data.text || data.snippet || data.body || '',\n    subject: data.Subject || data.subject || '',\n    thread_id: data.threadId || '',\n    message_id: data.id || ''\n  }\n}];"
      },
      "id": "node-normalise-gmail",
      "name": "Normalise: Gmail",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 100]
    },

    {
      "parameters": {
        "jsCode": "// Normalise Facebook Messenger webhook payload\nconst body = $json.body || $json;\nlet senderName = 'Customer';\nlet senderId = '';\nlet messageText = '';\n\ntry {\n  const entry = body.entry && body.entry[0];\n  const messaging = entry && entry.messaging && entry.messaging[0];\n  senderId = messaging && messaging.sender && messaging.sender.id || '';\n  messageText = messaging && messaging.message && messaging.message.text || '';\n} catch(e) {}\n\nreturn [{\n  json: {\n    channel_source: 'facebook',\n    sender_name: senderName,\n    sender_contact: senderId,\n    message_content: messageText,\n    raw_payload: JSON.stringify(body)\n  }\n}];"
      },
      "id": "node-normalise-facebook",
      "name": "Normalise: Facebook",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 240]
    },

    {
      "parameters": {
        "jsCode": "// Normalise Instagram DM webhook payload\nconst body = $json.body || $json;\nlet senderId = '';\nlet messageText = '';\n\ntry {\n  const entry = body.entry && body.entry[0];\n  const messaging = entry && entry.messaging && entry.messaging[0];\n  senderId = messaging && messaging.sender && messaging.sender.id || '';\n  messageText = messaging && messaging.message && messaging.message.text || '';\n} catch(e) {}\n\nreturn [{\n  json: {\n    channel_source: 'instagram',\n    sender_name: 'Instagram User',\n    sender_contact: senderId,\n    message_content: messageText,\n    raw_payload: JSON.stringify(body)\n  }\n}];"
      },
      "id": "node-normalise-instagram",
      "name": "Normalise: Instagram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 380]
    },

    {
      "parameters": {
        "jsCode": "// Normalise Twilio SMS webhook payload\nconst body = $json.body || $json;\nconst from = body.From || '';\nconst messageText = body.Body || '';\n\nreturn [{\n  json: {\n    channel_source: 'sms',\n    sender_name: 'SMS Customer',\n    sender_contact: from,\n    message_content: messageText,\n    raw_payload: JSON.stringify(body)\n  }\n}];"
      },
      "id": "node-normalise-sms",
      "name": "Normalise: SMS (Twilio)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 520]
    },

    {
      "parameters": {
        "jsCode": "// Normalise WhatsApp Business API webhook payload\nconst body = $json.body || $json;\nlet senderPhone = '';\nlet messageText = '';\nlet senderName = 'WhatsApp Customer';\n\ntry {\n  const entry = body.entry && body.entry[0];\n  const changes = entry && entry.changes && entry.changes[0];\n  const value = changes && changes.value;\n  const messages = value && value.messages && value.messages[0];\n  const contacts = value && value.contacts && value.contacts[0];\n  senderPhone = messages && messages.from || '';\n  messageText = messages && messages.text && messages.text.body || '';\n  senderName = contacts && contacts.profile && contacts.profile.name || 'WhatsApp Customer';\n} catch(e) {}\n\nreturn [{\n  json: {\n    channel_source: 'whatsapp',\n    sender_name: senderName,\n    sender_contact: senderPhone,\n    message_content: messageText,\n    raw_payload: JSON.stringify(body)\n  }\n}];"
      },
      "id": "node-normalise-whatsapp",
      "name": "Normalise: WhatsApp",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 660]
    },

    {
      "parameters": {
        "jsCode": "// Normalise website contact form submission\nconst body = $json.body || $json;\nconst name = body.name || body.full_name || body.customer_name || 'Website Visitor';\nconst email = body.email || body.customer_email || '';\nconst message = body.message || body.enquiry || body.body || '';\n\nreturn [{\n  json: {\n    channel_source: 'website_form',\n    sender_name: name,\n    sender_contact: email,\n    message_content: message,\n    raw_payload: JSON.stringify(body)\n  }\n}];"
      },
