        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 300,\n  \"system\": \"You are a helpful assistant for {{ $json.business_name }}, a {{ $json.business_type }} in {{ $json.business_city }}, UK. Reply to customer enquiries warmly and professionally. Answer questions about the business, take booking requests, and ask for their contact details if they want to book. Keep replies under 3 sentences. British English. Never make up specific details like prices or availability — instead say you'll get back to them shortly with that information.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"A customer contacted us via {{ $json.channel_source }}. Their name is {{ $json.sender_name }}. Their message is: {{ $json.message_content }}\\n\\nPlease write a warm, helpful reply on behalf of {{ $json.business_name }}.\"\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
