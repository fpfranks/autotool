    {
      "parameters": {
        "jsCode": "// Extract the text reply from Claude API response\nconst response = $json;\nlet aiReply = '';\n\ntry {\n  aiReply = response.content[0].text;\n} catch(e) {\n  aiReply = 'Thank you for getting in touch! We\\'ve received your message and will get back to you shortly. — ' + $('Set Business Context').first().json.business_name;\n}\n\nconst ctx = $('Set Business Context').first().json;\n\nreturn [{\n  json: {\n    ...ctx,\n    ai_reply: aiReply\n  }\n}];"
      },
