    {
      "parameters": {
        "jsCode": "// Build summary email body from today's interactions\nconst items = $input.all();\nconst today = new Date().toLocaleDateString('en-GB');\n\nlet totalCount = items.length;\nconst channelCounts = {};\n\nfor (const item of items) {\n  const ch = item.json.channel || item.json.channel_source || 'unknown';\n  channelCounts[ch] = (channelCounts[ch] || 0) + 1;\n}\n\nlet channelSummary = Object.entries(channelCounts)\n  .map(([ch, count]) => `  • ${ch}: ${count} interaction${count !== 1 ? 's' : ''}`)\n  .join('\\n');\n\nif (totalCount === 0) {\n  channelSummary = '  • No interactions recorded today.';\n}\n\nlet interactionList = '';\nif (items.length > 0) {\n  interactionList = items.slice(0, 20).map((item, i) => {\n    const d = item.json;\n    return `${i+1}. [${d.channel || 'unknown'}] ${d.sender_name || 'Unknown'} — \"${(d.message_received || '').substring(0, 80)}...\"\\n   Reply: \"${(d.reply_sent || '').substring(0, 80)}...\"\\n`;\n  }).join('\\n');\n}\n\nconst body = `Good evening!\\n\\nHere is your AI Reply Bot daily summary for ${today}:\\n\\nTOTAL ENQUIRIES HANDLED: ${totalCount}\\n\\nBY CHANNEL:\\n${channelSummary}\\n\\n${interactionList}\\nHave a great evening!\\n\\nPhillips Automates`;\n\nreturn [{ json: { summary_body: body, total_count: totalCount, date: today } }];"
      },
      "id": "node-build-summary",
      "name": "Build Summary Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 1000]
    },

    {
      "parameters": {
